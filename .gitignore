# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# claude code local artifacts (launch configs, scheduled task locks)
.claude/

# local audit-log scratch from agent work — never commit
_tmp/
scratch/
# Patient assets — CUVET-internal teaching cases MUST land under a
# cuvet-internal/ subdir (anywhere in the tree). This pattern keeps
# the existing CC BY 4.0 .dcm in /public/cases untouched while
# blocking everything sourced from the hospital dump.
**/cuvet-internal/
# Raw Synapse exports — anything containing "Synapse" in the filename
# at top level. The CC BY 4.0 cases never have this token.
Synapse*.zip
SynapseExport*

# Phase 8 — test artifacts
/playwright-report/
/test-results/
/.vitest-cache
