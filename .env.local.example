# ============================================================================
# cuvetsmo-imaging · .env.local.example
# ============================================================================
# Copy to `.env.local` and fill in. Both vars are NEXT_PUBLIC_* because the
# anon key is safe to ship in the browser bundle (RLS gates real access).
#
# When BOTH vars are blank/missing, the app falls back to the static
# lib/cases.ts CASES array — useful for SSG builds before Supabase wired.
#
# Provision:
#   1. Project lives in Palm's CUVETSMO Supabase org (Account B), project
#      slug TBD when Palm creates it.
#   2. Anon key:   mcp__supabase-cuvetsmo__get_publishable_keys
#   3. Project URL: mcp__supabase-cuvetsmo__get_project_url
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
